# =============================================================================
# Mewati Institute of Technology - Online Examination Platform
# Environment variables example. Copy this file to .env and fill in real values.
# =============================================================================

# Core Django
DEBUG=True
SECRET_KEY=change-me-to-a-long-random-string
DJANGO_SETTINGS_MODULE=config.settings.development
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
# Leave DATABASE_URL empty to use SQLite (default for development)
# Example PostgreSQL: postgresql://user:password@localhost:5432/mit_exam_db
DATABASE_URL=

# Redis / Celery (leave empty to use in-memory cache + run Celery synchronously)
REDIS_URL=
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CELERY_TASK_ALWAYS_EAGER=True

# Email
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=Mewati Institute of Technology <noreply@mewatitech.edu>

# Frontend / CORS
FRONTEND_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Media storage (Cloudinary). Leave blank to use local file storage.
USE_CLOUDINARY=False
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Databricks AI Code Conversion / Assistant
DATABRICKS_URL=https://xxxxx.com
DATABRICKS_TOKEN=xxxxx
DATABRICKS_ENDPOINT=xxxxxx

# JWT lifetimes (minutes / days)
JWT_ACCESS_TOKEN_LIFETIME_MIN=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7
